# ─── MongoDB Atlas ───────────────────────────────────────────────
# Free M0 cluster connection string. Include the DB name (e.g. /mockmate_db).
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/mockmate_db

# ─── Server ──────────────────────────────────────────────────────
# Render injects PORT automatically; locally defaults to 5000.
PORT=5000
# MUST be "production" on Render so secure / SameSite=None cookies work.
NODE_ENV=


# ─── Auth (use long random strings — NOT these placeholders) ─────
ACCESS_TOKEN_SECRET=replace_with_a_long_random_string
REFRESH_TOKEN_SECRET=replace_with_a_different_long_random_string
# 2h covers a full interview + Render cold-start reconnects on free tier.
ACCESS_TOKEN_EXPIRY=2h
REFRESH_TOKEN_EXPIRY=7d

# ─── CORS ────────────────────────────────────────────────────────
# Your deployed Vercel frontend origin (no trailing slash).
CORS_ORIGIN=https://your-app.vercel.app

# ─── Email verification (Brevo HTTP API) ─────────────────────────
# Use the HTTP API (not SMTP) — Render and most PaaS hosts block outbound SMTP.
# Brevo → SMTP & API → API Keys → Generate a new API key (xkeysib-...).
BREVO_API_KEY=
# Must be a verified sender in your Brevo account (Senders & Domains → Senders).
EMAIL_FROM=MockMate <no-reply@yourdomain.com>
# Front-end origin used to build verification links (no trailing slash).
FRONTEND_URL=https://your-app.vercel.app

# ─── Code Execution (Judge0 CE public instance — free, no key) ───
JUDGE0_API_URL=https://ce.judge0.com
# Optional RapidAPI fallback:
# JUDGE0_API_KEY=
# JUDGE0_API_HOST=judge0-ce.p.rapidapi.com
